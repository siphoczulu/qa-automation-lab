{
  "name": "qa-automation-lab",
  "version": "1.0.0",
  "description": "Portfolio QA automation project using Playwright, API testing, and GitHub Actions CI.",
  "author": "Sipho Zulu",
  "license": "ISC",
  "private": true,
  "type": "commonjs",
  "keywords": [
    "qa",
    "qa-automation",
    "software-testing",
    "playwright",
    "api-testing",
    "end-to-end-testing",
    "e2e",
    "ci",
    "github-actions",
    "portfolio"
  ],
  "scripts": {
    "setup": "npm ci && npx playwright install chromium",
    "test": "playwright test",
    "test:ui": "playwright test tests/todo.spec.ts",
    "test:api": "playwright test tests/api-jsonplaceholder.spec.ts",
    "test:headed": "playwright test --headed",
    "test:report": "playwright show-report",
    "test:debug": "playwright test --debug"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/siphoczulu/qa-automation-lab.git"
  },
  "bugs": {
    "url": "https://github.com/siphoczulu/qa-automation-lab/issues"
  },
  "homepage": "https://github.com/siphoczulu/qa-automation-lab#readme",
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/node": "^25.0.6"
  }
}